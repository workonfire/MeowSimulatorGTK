# GTKwinInstaller configuration for Meow Simulator
# Build with: make -C installer package-windows INSTALLER_ENV=../installer.env
# (invoked automatically via: make package-windows)

APP_NAME=Meow Simulator
APP_DESCRIPTION=Click. Meow. Repeat.
PUBLISHER=wzium
APP_ID=com.wzium.MeowSimulator
APP_EXE=MeowSimulatorRust.exe
LICENSE_FILE=LICENSE
APP_ICON_DARK=0

# Paths are relative to the installer/ submodule directory
APP_DIR=../dist/windows
ASSETS_DIR=../installer-assets
LICENSE=../LICENSE
PO_DIR=../installer-po
